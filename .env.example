# DocketDrift environment template.
# Copy to `.env` locally for dev, or to /home/private/.env on the NFSN site
# for production. NEVER commit the real `.env`.

# --- Django -----------------------------------------------------------------
# Generate a fresh production SECRET_KEY before deploying:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Comma-separated. Use a leading dot for wildcard subdomains (e.g. .docketdrift.com).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,docketdrift.com,.docketdrift.com

# --- Database ---------------------------------------------------------------
# 'sqlite' (default, local dev) or 'mariadb' (production on NFSN).
DOCKETDRIFT_DB=sqlite

# Only used when DOCKETDRIFT_DB=mariadb.
DOCKETDRIFT_DB_HOST=madmaster.db
DOCKETDRIFT_DB_NAME=docketdrift
DOCKETDRIFT_DB_USER=docketdrift_app
DOCKETDRIFT_DB_PASSWORD=

# --- CourtListener ----------------------------------------------------------
# Free token at https://www.courtlistener.com/profile/api-token/ .
COURTLISTENER_TOKEN=
